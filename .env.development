# Application Name
VITE_APP_NAME=知构

# API Gateway URL
VITE_API_BASE_URL=/api/v1

# Upload Service URL (zhicore-upload microservice)
VITE_UPLOAD_API_URL=/api/v1/upload

# WebSocket URL
# 开发环境走同源 /ws，由 Vite 代理转发到 gateway:8000
VITE_WS_URL=/ws
VITE_ENABLE_REALTIME=true

# CDN URL (optional)
VITE_CDN_URL=

# Error Reporting URL (optional, e.g., Sentry DSN)
VITE_ERROR_REPORT_URL=

# Environment
VITE_ENV=development
