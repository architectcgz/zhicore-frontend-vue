{
  "name": "zhicore-frontend-vue",
  "version": "1.0.0",
  "description": "知构（ZhiCore）- 基于微服务架构的内容社区系统前端应用",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "vue-tsc && vite build",
    "build:check:admin": "vue-tsc -p tsconfig.admin-slice.json --noEmit",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:admin": "vitest run test/api/admin.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "prepare": "husky install",
    "check:contrast": "tsx scripts/check-color-contrast.ts",
    "migrate:tests": "tsx scripts/migrate-tests.ts"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@tanstack/vue-query": "^5.92.9",
    "@tanstack/vue-query-devtools": "^6.1.4",
    "@vueuse/core": "^10.7.2",
    "@vueuse/motion": "^2.1.0",
    "axios": "^1.6.5",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.10",
    "dompurify": "^3.0.8",
    "echarts": "^6.0.0",
    "element-plus": "^2.5.4",
    "markdown-it": "^14.0.0",
    "pinia": "^2.1.7",
    "shiki": "^1.0.0",
    "vee-validate": "^4.12.4",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "yup": "^1.3.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.0",
    "@commitlint/config-conventional": "^18.6.0",
    "@testing-library/vue": "^8.0.1",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^13.0.7",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vitest/coverage-v8": "^1.6.1",
    "@vue/test-utils": "^2.4.3",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "fast-check": "^3.15.1",
    "husky": "^8.0.3",
    "jsdom": "^23.2.0",
    "postcss": "^8.4.33",
    "prettier": "^3.2.4",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "5.3.3",
    "vite": "^5.0.11",
    "vitest": "^1.2.1",
    "vue-tsc": "^1.8.27"
  }
}
