# Application Name
VITE_APP_NAME=知构

# API Gateway URL
VITE_API_BASE_URL=https://api.yourdomain.com/api/v1

# Upload Service URL (zhicore-upload microservice)
VITE_UPLOAD_API_URL=https://upload.yourdomain.com/api/v1/upload

# WebSocket URL
VITE_WS_URL=wss://api.yourdomain.com/ws
VITE_ENABLE_REALTIME=true

# CDN URL
VITE_CDN_URL=https://cdn.yourdomain.com

# Error Reporting URL (e.g., Sentry DSN)
VITE_ERROR_REPORT_URL=https://your-sentry-dsn@sentry.io/project-id

# Environment
VITE_ENV=production
